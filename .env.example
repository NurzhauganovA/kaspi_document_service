# ---------- Application ----------
APP_ENV=development
APP_DEBUG=false
SECRET_KEY=secret_key

# ---------- PostgreSQL ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=documents

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---------- Kafka ----------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_INPUT_TOPIC=documents.incoming
KAFKA_OUTPUT_TOPIC=documents.processed
KAFKA_CONSUMER_GROUP=document-processor
